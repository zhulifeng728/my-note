{
  "name": "notes-app-desktop",
  "version": "1.0.0",
  "description": "本地优先跨设备笔记应用 - 桌面端",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron-dev": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "npm run build:electron && vite build && electron-builder",
    "build:mac": "npm run build -- --mac",
    "build:win": "npm run build -- --win",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tiptap/extension-color": "^2.2.4",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-task-item": "^2.2.4",
    "@tiptap/extension-task-list": "^2.2.4",
    "@tiptap/extension-text-style": "^2.2.4",
    "@tiptap/extension-underline": "^2.2.4",
    "@tiptap/starter-kit": "^2.2.4",
    "@tiptap/vue-3": "^2.2.4",
    "better-sqlite3": "^9.4.3",
    "bonjour-service": "^1.2.1",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "express": "^4.18.3",
    "pinia": "^3.0.0",
    "sharp": "^0.34.5",
    "uuid": "^9.0.1",
    "vue": "^3.4.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-electron": "^0.28.4",
    "wait-on": "^7.2.0"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^6.0.6"
  }
}
